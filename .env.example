# Copy this file to .env.local and fill in real values.
# See docs/DEPLOYMENT.md for step-by-step instructions on where each of these comes from.

# --- MongoDB Atlas ---
# Create a free (M0) cluster at https://cloud.mongodb.com, then get the connection string
# from "Connect" > "Drivers". Replace <password> and add the database user you create.
MONGODB_URI=

# --- Google OAuth (Auth.js) ---
# Create an OAuth Client ID (Web application) at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google (add your prod URL too)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Auth.js session encryption secret. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# --- Web push (VAPID) ---
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# --- PostHog analytics (optional — app works fine without it) ---
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
POSTHOG_KEY=
POSTHOG_HOST=https://app.posthog.com

# --- Live tracking (optional — falls back to manual entry without it) ---
AVIATIONSTACK_API_KEY=
RAILWAY_API_KEY=

# --- Transactional email (optional but recommended — push-only otherwise) ---
# Sign up at https://resend.com (free tier), create an API key.
RESEND_API_KEY=
# Must be a verified sender/domain in Resend, or use their shared onboarding@resend.dev for testing.
RESEND_FROM_EMAIL=Campus Travel <onboarding@resend.dev>

# --- Cron protection (any random string; also set in Vercel env vars) ---
CRON_SECRET=

# --- Feedback (optional — Google Form URL for user feedback) ---
NEXT_PUBLIC_FEEDBACK_URL=

# Optional: public repo URL, shown as a GitHub link in the nav
NEXT_PUBLIC_GITHUB_URL=
